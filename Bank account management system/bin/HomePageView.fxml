<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?> 
<?import javafx.scene.control.Label?> 
<?import javafx.scene.control.TextArea?> 
<?import javafx.scene.control.TextField?> 
<?import javafx.scene.image.Image?> 
<?import javafx.scene.image.ImageView?> 
<?import javafx.scene.layout.BorderPane?> 
<?import javafx.scene.layout.HBox?> 
<?import javafx.scene.layout.StackPane?> 
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="HomePageController">
    <!-- Header Section -->
    <top>
        <VBox fx:id="headerBox" alignment="CENTER" spacing="10" style="-fx-padding: 10; -fx-background-color: linear-gradient(to right, #4a90e2, #6a5acd);">
            <HBox alignment="CENTER" spacing="20">
                <ImageView fitHeight="50" fitWidth="50" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@images/logo.png" />
                    </image>
                </ImageView>
                <VBox alignment="CENTER" spacing="2">
                   <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Times New Roman';" text="Titanium" />
                   <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Times New Roman';" text="Bank" />
                </VBox>
            </HBox>
            <Label style="-fx-font-size: 10px; -fx-text-fill: white; -fx-font-style: italic;" text="Where Your Money Feels Safe, Like Really Safe🔒 " />
        </VBox>
    </top>

    <!-- Center Section -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 20;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Manage your accounts wisely"
                       style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-color: linear-gradient(to right, #4a90e2, #6a5acd); -fx-background-radius: 5; -fx-padding: 5 10;" />
                <!-- Image Section After Label -->
                <ImageView fx:id="bankImage" fitHeight="200" fitWidth="400" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@images/Bank.png" />
                    </image>
                </ImageView>
            </HBox>

            <!-- Animated Icon (Appears and Slides up) -->
            <ImageView fx:id="animatedIcon" fitHeight="100" fitWidth="100" pickOnBounds="true" preserveRatio="true" style="-fx-opacity: 0;">
                <image>
                    <Image url="@images/animated-icon.png" />
                </image>
            </ImageView>

            <!-- Buttons Below Image -->
            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
                <!-- Login Button -->
                <Button fx:id="loginButton" text="🔑 Login" onAction="#navigateToLogin" styleClass="button" 
                        style="-fx-background-color: linear-gradient(to right, #4a90e2, #6a5acd); -fx-text-fill: White; -fx-font-weight: bold; -fx-min-width: 200px; -fx-max-width: 200px; -fx-pref-height: 50px;  -fx-background-radius: 10;
    -fx-border-radius: 10;-fx-border-color: transparent;  -fx-padding: 10 20;" />
                <!-- Register Button -->
                <Button fx:id="registerButton" text="📝 Register" onAction="#navigateToRegister" styleClass="button" 
                        style="-fx-background-color: linear-gradient(to right, #4a90e2, #6a5acd); -fx-text-fill: White; -fx-font-weight: bold; -fx-min-width: 200px; -fx-max-width: 200px; -fx-pref-height: 50px; -fx-background-radius: 10;
    -fx-border-radius: 10;-fx-border-color: transparent;  -fx-padding: 10 20;" />
            </HBox>
        </VBox>
    </center>

    <!-- Footer Section -->
    <bottom>
        <StackPane alignment="BOTTOM_RIGHT" style="-fx-padding: 10;">
            <!-- Chatbot Icon -->
            <Button fx:id="chatIcon" styleClass="chat-icon" onAction="#toggleChatbot">
                <graphic>
                    <ImageView fitWidth="40" fitHeight="40">
                        <image>
                            <Image url="https://img.icons8.com/ios-filled/30/4D4D4D/ai-chatting.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <!-- Chatbot Box -->
            <VBox fx:id="chatbotBox" spacing="5" alignment="CENTER" styleClass="chat-popup" visible="false" managed="false" 
                  style="-fx-border-color: purple; -fx-border-width: 2; -fx-padding: 5; -fx-border-radius: 10px;">
                <Label text="Titanium Bank AI" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                <TextArea fx:id="chatArea" editable="false" prefHeight="120" prefWidth="180" styleClass="chat-area" />
                <HBox spacing="5">
                    <TextField fx:id="userInput" promptText="Hello, how can I assist you..." HBox.hgrow="ALWAYS" styleClass="chat-input" />
                    <Button text="Send" onAction="#handleChatInput" styleClass="chat-button" />
                </HBox>
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Clear" onAction="#clearChatArea" styleClass="clear-chat-button" />
                    <Button text="Close" onAction="#toggleChatbot" styleClass="close-chat-button" />
                </HBox>
            </VBox>
        </StackPane>
    </bottom>
</BorderPane>
