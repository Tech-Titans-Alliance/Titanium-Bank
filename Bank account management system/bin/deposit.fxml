<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20" styleClass="vbox" stylesheets="@styles.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="DepositController">
    <!-- Updated Deposit Funds Text with color and emoji -->
    <Text style="-fx-font-size: 24px; -fx-fill: rgb(155, 6, 105);" text="Deposit Funds 💰" />
    
    <!-- ComboBox for account selection -->
    <ComboBox fx:id="accountDropdown" promptText="Select Account" />
    
    <!-- TextField for amount input -->
    <TextField fx:id="amountField" promptText="Amount" />
    
    <!-- HBox for centering the buttons with space between them -->
    <HBox spacing="20" alignment="CENTER">
        <Button text="Deposit Money" onAction="#deposit" style="-fx-font-weight: bold; -fx-text-fill: black;" />
        <Button text="Back To Dashboard" onAction="#goBack" style="-fx-font-weight: bold; -fx-text-fill: black;" />
    </HBox>
</VBox>


